{
	"name": "detain/monolog-mydb",
	"description": "A Monolog handler that writes log records to a MySQL table via the detain/db_abstraction layer.",
	"keywords": ["log", "logging", "monolog", "mysql", "database"],
	"homepage": "https://github.com/detain/monolog-mysql",
	"license": "MIT",
	"authors": [
		{
			"name": "Joe Huss",
			"email": "detain@interserver.net"
		}
	],
	"require": {
		"php": ">=8.2",
		"ext-mysqli": "*",
		"monolog/monolog": "^2.0 || ^3.0",
		"detain/db_abstraction": "dev-master"
	},
	"autoload": {
		"psr-4": {
			"MyDbHandler\\": "src/MyDbHandler/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5"
	}
}
