{
    "name": "detain/monolog-mydb",
    "description": "A handler for Monolog that sends messages to MySQL",
    "keywords": [
        "log",
        "logging",
        "monolog",
        "monolog-handler",
        "mysql",
        "mysqli",
        "pdo",
        "database",
        "sql",
        "syslog",
        "psr-3",
        "handler",
        "logger",
        "alerting",
        "monitoring",
        "mysql-logger",
        "php",
        "php-library"
    ],
    "homepage": "https://github.com/detain/monolog-mysql",
    "license": "MIT",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net"
        }
    ],
    "require": {
        "monolog/monolog": ">1.4.0",
        "detain/db_abstraction": "dev-master"
    },
    "autoload": {
               "psr-4": {
                       "MySQLHandler\\": "src/"
               }
    },
  "require": {
    "php": "^7.2",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "monolog/monolog": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.5",
    "doctrine/dbal": "^2.10",
    "psy/psysh": "^0.10.4",
    "fzaninotto/faker": "^1.9"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  }
}
